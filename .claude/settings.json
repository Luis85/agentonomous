{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run format)",
      "Bash(npm run format:check)",
      "Bash(npm run build)",
      "Bash(npm run analyze)",
      "Bash(npm run verify)",
      "Bash(npm run docs)",
      "Bash(npm run changeset)",
      "Bash(npm run demo:*)",
      "Bash(npm outdated)",
      "Bash(npm outdated:*)",
      "Bash(npm info *)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git switch develop)",
      "Bash(git switch main)",
      "Bash(git switch *)",
      "Bash(git switch -c *)",
      "Bash(git checkout *)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin refactor/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin test/*)",
      "Bash(git push -u origin hotfix/*)",
      "Bash(git push -u origin release/*)",
      "Bash(git push -u origin claude/*)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin refactor/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin test/*)",
      "Bash(git push origin hotfix/*)",
      "Bash(git push origin release/*)",
      "Bash(git push origin claude/*)",
      "Bash(git push --force-with-lease origin feat/*)",
      "Bash(git push --force-with-lease origin fix/*)",
      "Bash(git push --force-with-lease origin refactor/*)",
      "Bash(git push --force-with-lease origin docs/*)",
      "Bash(git push --force-with-lease origin chore/*)",
      "Bash(git push --force-with-lease origin test/*)",
      "Bash(git push --force-with-lease origin hotfix/*)",
      "Bash(git push --force-with-lease origin release/*)",
      "Bash(git push --force-with-lease origin claude/*)",
      "Bash(git fetch origin)",
      "Bash(git fetch origin:*)",
      "Bash(git fetch --prune origin)",
      "Bash(git pull origin develop)",
      "Bash(git pull origin main)",
      "Bash(git pull origin *)",
      "Bash(git config --get *)",
      "Bash(git config --list)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git stash show *)",
      "Bash(git stash push *)",
      "Bash(git stash pop)",
      "Bash(git stash pop *)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push origin develop)",
      "Bash(git push origin develop:*)",
      "Bash(git push origin demo)",
      "Bash(git push origin demo:*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force origin develop*)",
      "Bash(git push --force origin demo*)",
      "Bash(git push -f origin main*)",
      "Bash(git push -f origin develop*)",
      "Bash(git push -f origin demo*)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push --force-with-lease origin develop*)",
      "Bash(git push --force-with-lease origin demo*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/develop)",
      "Bash(git reset --hard origin/demo)",
      "Bash(git branch -D develop)",
      "Bash(git branch -D main)",
      "Bash(git branch -D demo)",
      "Bash(git branch -d develop)",
      "Bash(git branch -d main)",
      "Bash(git branch -d demo)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf src*)",
      "Bash(rm -rf tests*)",
      "Bash(rm -rf .git*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}
